# Copy this file to .env and fill in the values before running.

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_PASSWORD=change_me

# Full connection string (used by the backend directly when not in Docker)
DATABASE_URL=postgresql://postgres:change_me@localhost:5432/nutritrack

# ── JWT ─────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_string

# ── Server ──────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── CORS (production only) ───────────────────────────────────
# In development CORS is open to all origins automatically.
# In production set this to your frontend's domain.
CORS_ORIGIN=https://your-frontend-domain.com
