# Copy this file to .env and fill in the values before running.

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_PASSWORD=change_me

# Full connection string (used by the backend directly when not in Docker)
DATABASE_URL=postgresql://postgres:change_me@localhost:5432/nutritrack

# ── JWT ─────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_string

# ── Server ──────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── AI (Groq) ────────────────────────────────────────────────
# Free key from https://console.groq.com — powers food-photo
# recognition and the AI coach. Leave blank to disable AI features.
GROQ_API_KEY=

# ── CORS (production only) ───────────────────────────────────
# In development CORS is open to all origins automatically.
# In production set this to your frontend's domain.
CORS_ORIGIN=https://your-frontend-domain.com

# ── Email / SMTP (for forgot-password) ───────────────────────
# Use Mailtrap (https://mailtrap.io) or Ethereal for dev testing.
# Leave blank to skip email sending (token logged to console instead).
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=change_me
SMTP_PASS=change_me
SMTP_FROM=noreply@nutritrack.app

# Deep-link base for password reset email
APP_BASE_URL=nutritrack://reset-password
